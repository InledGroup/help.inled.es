---
import "../styles/glass.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link
            rel="icon"
            type="image/png"
            href="https://hosted.inled.es/inled-logo-full.png"
        />
        <meta name="generator" content={Astro.generator} />
        <title>{title} | Knowledge base</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <header class="main-header">
            <div class="container header-content">
                <a href="/" class="logo-link">
                    <img
                        src="https://hosted.inled.es/inled-logo-full.png"
                        alt="Inled Logo"
                        class="logo-img"
                    />
                </a>
                <nav class="nav-links">
                    <a href="/" class="nav-item">Home</a>
                    <a
                        href="https://github.com/InledGroup/help.inled.es/issues/new"
                        target="_blank"
                        class="gh-btn glass-card"
                    >
                        New doc
                    </a>
                </nav>
            </div>
        </header>

        <main class="container">
            <slot />
        </main>

        <footer class="main-footer">
            <div class="container">
                <p>&copy; {new Date().getFullYear()} help.inled.es</p>
            </div>
        </footer>
    </body>
</html>

<style is:global>
    .main-header {
        padding: 2rem 0;
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo-img {
        height: 32px;
        width: auto;
        filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.2));
    }

    .nav-links {
        display: flex;
        gap: 1.5rem;
        align-items: center;
    }

    .nav-item {
        font-weight: 500;
        opacity: 0.7;
        font-size: 0.9rem;
    }

    .nav-item:hover {
        opacity: 1;
    }

    .gh-btn {
        padding: 0.6rem 1.2rem;
        font-size: 0.9rem;
        font-weight: 600;
        border-radius: 50px;
    }

    .gh-btn:hover {
        background: rgba(255, 255, 255, 0.15);
    }

    .main-footer {
        padding: 4rem 0 2rem;
        text-align: center;
        font-size: 0.9rem;
        opacity: 0.6;
    }
</style>
