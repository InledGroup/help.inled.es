---
import Layout from "../ui/layouts/Layout.astro";
import { ArticleService } from "../infrastructure/github/GitHubService";

const articleService = new ArticleService();
const articles = await articleService.getAllArticles();

const groupedArticles = articles.reduce(
    (acc, article) => {
        const group = article.group || "General";
        if (!acc[group]) acc[group] = [];
        acc[group].push(article);
        return acc;
    },
    {} as Record<string, typeof articles>,
);

const groups = Object.keys(groupedArticles);
---

<Layout title="Ayuda">
    <section class="hero">
        <h1>How we can <span>help you?</span></h1>
        <p>Explore our knowledge base, made and updated by AI Agents.</p>
    </section>

    <div class="grid-categories">
        {
            groups.map((group) => (
                <div class="category-card glass-card">
                    <h2>{group}</h2>
                    <div class="links">
                        {groupedArticles[group].map((article) => (
                            <a
                                href={`/help/${article.slug}`}
                                class="article-link"
                            >
                                {article.title}
                            </a>
                        ))}
                    </div>
                </div>
            ))
        }

        {
            articles.length === 0 && (
                <div class="category-card glass-card empty">
                    <p>
                        No se encontraron artículos. El sistema está listo para
                        recibir Issues.
                    </p>
                </div>
            )
        }
    </div>
</Layout>

<style>
    .hero {
        text-align: center;
        padding: 6rem 0 4rem;
    }

    h1 {
        font-size: 4rem;
        font-weight: 700;
        margin-bottom: 1rem;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
    }

    h1 span {
        font-weight: 300;
    }

    .hero p {
        font-size: 1.4rem;
        opacity: 0.9;
        font-weight: 300;
    }

    .grid-categories {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2.5rem;
        margin-top: 2rem;
    }

    .category-card {
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
    }

    h2 {
        margin-top: 0;
        font-size: 1.6rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
        text-align: center;
    }

    .links {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .article-link {
        font-size: 1.1rem;
        padding: 0.8rem 1.2rem;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .article-link:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: scale(1.02);
    }

    .empty {
        grid-column: 1 / -1;
        text-align: center;
        padding: 3rem;
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 2.5rem;
        }
        .hero {
            padding: 3rem 0;
        }
    }
</style>
