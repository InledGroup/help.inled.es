---
import Layout from "../../ui/layouts/Layout.astro";
import { ArticleService } from "../../infrastructure/github/GitHubService";
import { marked } from "marked";

export async function getStaticPaths() {
    const articleService = new ArticleService();
    const articles = await articleService.getAllArticles();

    return articles.map((article) => ({
        params: { slug: article.slug },
        props: { article },
    }));
}

const { article } = Astro.props;
const htmlContent = marked.parse(article.content);
---

<Layout title={article.title}>
    <article class="article-container">
        <header class="article-header glass-card">
            <div class="breadcrumb">
                <a href="/">Help</a> / <span>{article.group}</span>
            </div>
            <h1>{article.title}</h1>
            <div class="meta">
                <span
                    >Updated from {article.updatedAt.toLocaleDateString()}</span
                >
                <a
                    href={`/help/${article.slug}.md`}
                    class="raw-btn glass-card"
                    target="_blank"
                >
                    📄 View raw md
                </a>
            </div>
        </header>

        <div class="content glass-card" set:html={htmlContent} />

        <div class="actions">
            <a href="/" class="back-link glass-card">← Back to home</a>
        </div>
    </article>
</Layout>

<style is:global>
    .article-container {
        max-width: 900px;
        margin: 4rem auto;
    }

    .article-header {
        padding: 3rem;
        margin-bottom: 2rem;
        text-align: center;
    }

    .breadcrumb {
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        opacity: 0.7;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .article-header h1 {
        font-size: 3rem;
        margin: 0 0 1rem 0;
        font-weight: 700;
    }

    .meta {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        font-size: 0.9rem;
        opacity: 0.8;
    }

    .raw-btn {
        padding: 0.4rem 0.8rem;
        font-size: 0.8rem;
        font-weight: 600;
        border-radius: 8px;
        opacity: 1;
        transition: transform 0.2s ease;
    }

    .raw-btn:hover {
        transform: scale(1.05);
        background: rgba(255, 255, 255, 0.1);
    }
    .content {
        padding: 4rem;
        line-height: 1.8;
        font-size: 1.2rem;
        font-weight: 300;
    }

    .content h1,
    .content h2,
    .content h3 {
        margin-top: 2.5rem;
        margin-bottom: 1.2rem;
        font-weight: 600;
    }

    .content p {
        margin-bottom: 1.8rem;
    }

    .content a {
        text-decoration: underline;
        text-underline-offset: 4px;
    }

    .content code {
        background: rgba(255, 255, 255, 0.1);
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
        font-family: monospace;
        font-size: 0.9em;
    }

    .content pre {
        background: rgba(0, 0, 0, 0.4);
        padding: 2rem;
        border-radius: 16px;
        overflow-x: auto;
        margin: 2.5rem 0;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .actions {
        margin-top: 3rem;
        display: flex;
        justify-content: center;
    }

    .back-link {
        padding: 1rem 2rem;
        border-radius: 50px;
        font-weight: 600;
    }

    .back-link:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    @media (max-width: 768px) {
        .content {
            padding: 2rem;
            font-size: 1.1rem;
        }
        .article-header {
            padding: 2rem;
        }
        .article-header h1 {
            font-size: 2rem;
        }
    }
</style>
